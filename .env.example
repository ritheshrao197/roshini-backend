# ──────────────────────────────────────────────────
# Roshini's Home Products — Backend Environment
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit real credentials to version control.

# ── Database ─────────────────────────────────────
DATABASE=mongodb://127.0.0.1:27017/roshinis_ecommerce

# ── Server ────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── JWT Authentication ────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Braintree Payment Gateway ─────────────────────
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=
# Set to "production" when going live
BRAINTREE_ENV=sandbox

# ── PhonePe Payment Gateway ───────────────────────
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
# Set to "production" when going live
PHONEPE_MODE=sandbox
PHONEPE_SANDBOX_URL=https://api-preprod.phonepe.com/apis/pg-sandbox/pg/v1/pay
PHONEPE_PROD_URL=https://api.phonepe.com/apis/hermes/pg/v1/pay
PHONEPE_SANDBOX_STATUS_URL=https://api-preprod.phonepe.com/apis/pg-sandbox/pg/v1/status
PHONEPE_PROD_STATUS_URL=https://api.phonepe.com/apis/hermes/pg/v1/status

# ── PayU Payment Gateway ──────────────────────────
PAYU_MERCHANT_KEY=
PAYU_SALT=

# ── Cloudinary CDN ────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Resend Email Service ──────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Upstash Redis Cache ───────────────────────────
# Leave blank to use in-memory cache fallback
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── URLs ──────────────────────────────────────────
CLIENT_URL=http://localhost:3001
BACKEND_URL=http://localhost:8000

# ── Seed Script ───────────────────────────────────
# Used by seed.js to create the first super admin
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
